# Telegram bridge (tg_bridge.py) — copy to .env and fill in.
# The bridge is OWNER-ONLY: it ignores every chat except TG_BRIDGE_OWNER.

# Required: bot token from @BotFather
TG_BRIDGE_TOKEN=123456:your-bot-token-from-BotFather

# Required for security: your Telegram numeric user id (the only chat allowed to drive agents)
TG_BRIDGE_OWNER=123456789

# Where uploaded files/voice notes are stored, and the public base URL they're served at
TG_FILES_DIR=/home/ubuntu/pr/tgfiles
TG_FILES_DIR_IMG=/home/ubuntu/pr/tgimg
TG_FILES_URL=https://example.com/tgfiles

# Optional: path to the conversation log
# TG_CONVO_LOG=/home/ubuntu/pr/terminal/tg_convo.log
